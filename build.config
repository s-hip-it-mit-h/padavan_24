#!/bin/bash

# Железо и ядро
export CONFIG_FIRMWARE_PRODUCT_ID="MI-R3G"
export CONFIG_FIRMWARE_KERNEL="3.4"
export CONFIG_VENDOR=XIAOMI
export CONFIG_PRODUCT=MT7621

# WiFi (стабильность и скорость)
export CONFIG_FIRMWARE_WIFI2_DRIVER=4.1
export CONFIG_FIRMWARE_WIFI5_DRIVER=3.0

# Русский язык
export CONFIG_FIRMWARE_INCLUDE_LANG_RU=y

# USB и флешка
export CONFIG_FIRMWARE_ENABLE_USB=y
export CONFIG_FIRMWARE_ENABLE_EXT4=y
export CONFIG_FIRMWARE_ENABLE_FAT=y
export CONFIG_FIRMWARE_ENABLE_EXFAT=y
export CONFIG_FIRMWARE_ENABLE_FUSE=y
export CONFIG_FIRMWARE_ENABLE_SWAP=y

# Сеть (оставляем IPsec)
export CONFIG_FIRMWARE_INCLUDE_IPSET=y
export CONFIG_FIRMWARE_INCLUDE_SHORTCUT_FE=y
export CONFIG_FIRMWARE_INCLUDE_XFRM=y

# VPN и обход DPI
export CONFIG_FIRMWARE_INCLUDE_WIREGUARD=y
export CONFIG_FIRMWARE_INCLUDE_OPENVPN=y
export CONFIG_FIRMWARE_INCLUDE_NFQWS=y
export CONFIG_FIRMWARE_INCLUDE_SHADOWSOCKS=y

# DNS
export CONFIG_FIRMWARE_INCLUDE_DNSCRYPT=y
export CONFIG_FIRMWARE_INCLUDE_STUBBY=y
export CONFIG_FIRMWARE_INCLUDE_DOH=y

# Прокси (пусть будет)
export CONFIG_FIRMWARE_INCLUDE_PRIVOXY=y

# Медиасервер (для YouTube на телевизоре)
export CONFIG_FIRMWARE_INCLUDE_MINIDLNA=y
export CONFIG_FIRMWARE_INCLUDE_FFMPEG_NEW=y

# Принтер и файлы
export CONFIG_FIRMWARE_INCLUDE_LPRD=y
export CONFIG_FIRMWARE_INCLUDE_SMBD=y
export CONFIG_FIRMWARE_INCLUDE_FTPD=y

# Менеджер загрузок (оставляем)
export CONFIG_FIRMWARE_INCLUDE_ARIA=y
export CONFIG_FIRMWARE_INCLUDE_ARIA_WEB_CONTROL=y

# Торрент-клиент (выключаем — качаешь на ноуте)
# export CONFIG_FIRMWARE_INCLUDE_TRANSMISSION=y

# Безопасность
export CONFIG_FIRMWARE_INCLUDE_OPENSSL_EC=y
export CONFIG_FIRMWARE_INCLUDE_OPENSSL_EXE=y
export CONFIG_FIRMWARE_INCLUDE_HTTPS=y
export CONFIG_FIRMWARE_INCLUDE_OPENSSH=y

# Утилиты
export CONFIG_FIRMWARE_INCLUDE_TCPDUMP=y
export CONFIG_FIRMWARE_INCLUDE_CURL=y
export CONFIG_FIRMWARE_INCLUDE_IPERF3=y

# Сжатие
export CONFIG_CC_OPTIMIZE_FOR_SIZE=y
